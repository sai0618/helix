    "user-portal-memory-utilization": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "${DS_CLOUD_MONITORING}"
                    },
                    "group": "stackdriver",
                    "kind": "DataQuery",
	                    "spec": {
	                      "queryType": "promQL",
	                      "timeSeriesList": {
	                        "promQLQuery": {
	                          "projectName": "${project_id}",
	                          "expr": "avg by (container_name) (avg_over_time({\"__name__\"=\"kubernetes.io/container/memory/used_bytes\", \"monitored_resource\"=\"k8s_container\", \"project_id\"=\"${project_id}\", \"namespace_name\"=\"helix\", \"container_name\"=\"user-portal\"}[5m]))",
	                          "step": "60s"
