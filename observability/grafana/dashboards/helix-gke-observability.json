                    }
                  ]
                },
                "unit": "ms"
              },
              "overrides": []
            },
            "options": {
              "legend": {
                "calcs": [
                  "lastNotNull",
                  "max"
                ],
                "displayMode": "table",
                "placement": "bottom",
                "showLegend": true
              },
              "tooltip": {
                "mode": "multi",
                "sort": "desc"
              }
            }
          },
          "version": "12.4.0"
        }
      }
    },
    "user-portal-cpu-utilization": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "${DS_CLOUD_MONITORING}"
                    },
                    "group": "stackdriver",
                    "kind": "DataQuery",
	                    "spec": {
	                      "queryType": "promQL",
	                      "timeSeriesList": {
	                        "promQLQuery": {
	                          "projectName": "${project_id}",
	                          "expr": "sum by (container_name) (rate({\"__name__\"=\"kubernetes.io/container/cpu/core_usage_time\", \"monitored_resource\"=\"k8s_container\", \"project_id\"=\"${project_id}\", \"namespace_name\"=\"helix\", \"container_name\"=\"user-portal\"}[5m]))",
	                          "step": "60s"
	                        },
	                        "projectName": "${project_id}",
	                        "filters": [],
	                        "view": "FULL",
	                        "groupBys": []
	                      },
	                      "promQLQuery": {
	                        "projectName": "${project_id}",
	                        "expr": "sum by (container_name) (rate({\"__name__\"=\"kubernetes.io/container/cpu/core_usage_time\", \"monitored_resource\"=\"k8s_container\", \"project_id\"=\"${project_id}\", \"namespace_name\"=\"helix\", \"container_name\"=\"user-portal\"}[5m]))",
	                        "step": "60s"
	                      }
	                    },
                    "version": "v0"
                  },
                  "refId": "A"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
          }
        },
        "description": "CPU core usage rate for the user-portal container in the helix namespace.",
